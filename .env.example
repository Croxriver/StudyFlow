PORT=5188
NODE_ENV=development
JWT_SECRET=change-this-before-production
# Set true only for local development when SMS/email delivery is not available.
DEV_VERIFICATION_CODE_RESPONSE=false
# Optional 6-digit code that always passes phone/email verification. Leave empty in production.
VERIFICATION_BYPASS_CODE=

# Azure SQL connection settings
SQL_SERVER=your-server.database.windows.net
SQL_DATABASE=your-database
SQL_USER=your-sql-user
SQL_PASSWORD=your-sql-password
SQL_ENCRYPT=true
SQL_TRUST_SERVER_CERTIFICATE=false

# Signup email verification SMTP settings
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM="StudyFlow <no-reply@example.com>"

# Study completion attachment uploads
UPLOAD_DIR=C:\StudyFlow\uploads\study-attachments

# AI analysis for study attachments
# Supported: openai, openai-compatible, ollama
AI_PROVIDER=openai
AI_API_KEY=your-ai-api-key
AI_BASE_URL=
AI_MODEL=gpt-4.1-mini
# Optional. Use \n for line breaks when running as a Windows service.
AI_ANALYSIS_PROMPT=너는 초등/중등 학생의 학습 결과물을 검토하는 선생님 보조 AI야.\n첨부된 이미지는 학생이 학습 완료 후 등록한 시험지, 문제지, 풀이 노트일 수 있다.\n\n다음 형식으로 한국어로 분석해줘.\n\n1. 전체 요약\n2. 확인 가능한 학습 내용\n3. 잘한 점\n4. 보완이 필요한 점\n5. 오답 또는 실수로 보이는 부분\n6. 다음 학습 제안\n7. 선생님이 학생에게 전달하기 좋은 짧은 피드백\n\n주의:\n- 이미지에서 명확히 보이는 내용만 근거로 말해.\n- 보이지 않거나 확실하지 않은 내용은 추측하지 말고 "이미지상 확인이 어렵다"고 말해.\n- 학생을 비난하지 말고 선생님이 참고하기 좋은 표현으로 작성해.
# Backward-compatible OpenAI settings. AI_* values take priority when set.
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_ANALYSIS_PROMPT=

# Web Push VAPID keys
STUDYFLOW_WEB_URL=https://studyflow.csid.kr
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@example.com

# Firebase Admin for app push sending
# Use one of these:
FIREBASE_PROJECT_ID=your-firebase-project-id
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Toss Payments
# Put real values in .env or your encrypted env file. Never expose Secret Key to the browser.
PAYMENT_PROVIDER=toss
TOSS_PAYMENTS_CLIENT_KEY=test_ck_your-client-key
TOSS_PAYMENTS_SECRET_KEY=test_sk_your-secret-key

# InnoPay. Set PAYMENT_PROVIDER=innopay to use this module.
INNOPAY_MID=testpay01m
INNOPAY_MERCHANT_KEY=your-innopay-merchant-key
INNOPAY_PAY_METHOD=CARD
INNOPAY_CANCEL_URL=https://api.innopay.co.kr/api/cancelApi
INNOPAY_CANCEL_PASSWORD=your-innopay-cancel-password
